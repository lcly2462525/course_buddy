# course-buddy 环境变量配置
# 推荐使用 `bash setup.sh` 自动生成此文件
# 也可手动复制此模板为 .env 后修改

# LLM API key — 用于笔记生成（必需）和自然语言解析（可选）
LLM_API_KEY=sk-your-key-here
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://aihubmix.com/v1

# === 以下为可选配置 ===

# whisper-api 后端的 API key（默认复用 OPENAI_API_KEY）
# WHISPER_API_KEY=gsk_your-groq-key-here
# WHISPER_BASE_URL=https://api.groq.com/openai/v1

# whisper-cpp 模型路径（默认自动查找 ~/.local/share/whisper-cpp/ 下的模型）
# WHISPER_CPP_MODEL=/path/to/ggml-large-v3-turbo.bin
# WHISPER_CPP_BINARY=/opt/homebrew/bin/whisper-cli
