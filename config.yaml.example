# ============================================================
# course-buddy 配置文件
# ============================================================
# 此文件由 `bash setup.sh` 或 `cb init` 自动生成
# 也可手动复制此模板为 config.yaml 后修改

# Cookie 路径（自动管理，通常不需要修改）
cookies_path: ~/.config/canvas/cookies.json

# 数据根目录
root_dir: data

# ============================================================
# 课程配置
# ============================================================
# 运行 `cb init` 自动从 Canvas 获取你的课程
# 也可手动添加：在 Canvas (oc.sjtu.edu.cn) 查看课程 URL 获取 ID
# 例如 https://oc.sjtu.edu.cn/courses/88884 → ID 为 88884
courses: {}
  # "COURSE_ID":
  #   name: 课程名称
  #   aliases: [别名1, 别名2]       # 用于自然语言识别
  #   urls: [https://v.sjtu.edu.cn/course/COURSE_ID]
  #   note_rules:
  #     key_terms: [关键词1, 关键词2]  # Whisper 转录纠错

# ============================================================
# 转录设置
# ============================================================
transcribe:
  backend: whisper-cpp     # whisper-cpp（推荐）| whisper-api
  language: zh             # 转录语言提示
  target_langs: [zh, en]   # 质量检测目标语言
  clean_video: true        # 转录后删除视频（节省磁盘）
  clean_audio: true        # 转录后删除临时音频

# ============================================================
# LLM 设置（笔记生成）
# ============================================================
llm:
  enabled: true
  api_key_env: LLM_API_KEY        # 从 .env 读取此环境变量
  base_url: https://aihubmix.com/v1
  model: qwen3-max                # 推荐：性价比高
  temperature: 0.3

ask:
  llm:
    enabled: true
    model: qwen3-max
    temperature: 0
    api_key_env: LLM_API_KEY
